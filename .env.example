# ============================================================
# 智慧知識庫 .env 設定範本
# 複製此檔案為 .env 並填入你的設定
# ============================================================

# ── Neo4j ────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── Provider 選擇 ─────────────────────────────────────────────
# LLM provider:       ollama | openai | anthropic | gemini | grok
# Embedding provider: local  | openai | ollama
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=local

# ── Ollama（本地，需先啟動 ollama serve）────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5:7b
# Ollama Embedding（EMBEDDING_PROVIDER=ollama 時使用）
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── 本地 Embedding（EMBEDDING_PROVIDER=local 時使用）────────────
# 支援 HuggingFace 上的 sentence-transformers 模型
LOCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ── OpenAI ───────────────────────────────────────────────────
# LLM_PROVIDER=openai 或 EMBEDDING_PROVIDER=openai 時必填
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Anthropic Claude ─────────────────────────────────────────
# LLM_PROVIDER=anthropic 時必填
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Google Gemini ─────────────────────────────────────────────
# LLM_PROVIDER=gemini 時必填
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# ── xAI Grok ─────────────────────────────────────────────────
# LLM_PROVIDER=grok 時必填
GROK_API_KEY=xai-...
GROK_MODEL=grok-2

# ── Whisper 語音/影片轉譯 ─────────────────────────────────────
# 支援格式：.mp3 .mp4 .wav .m4a .ogg .flac .webm .mkv .avi
# 模型大小：tiny | base | small | medium | large-v3（越大越準但越慢）
WHISPER_MODEL_SIZE=base

# ── 系統行為 ──────────────────────────────────────────────────
CONCEPT_EXTRACTION_MAX=8
SCORE_THRESHOLD=0.70

# ── 資料路徑（目錄由程式自動建立，無需手動新增）──────────────────
#
# WORKSPACE_DIR：文件工作區
#   - 所有匯入的文件、知識圖譜子目錄（kg_xxx/）、暫存區（_staging/）均存放於此
#   - 預設為專案目錄下的 ./workspace
#   - 若文件量大或需存放在其他磁碟，可改為絕對路徑，例如：
#       Windows：WORKSPACE_DIR=D:/my_knowledge
#       Linux/Mac：WORKSPACE_DIR=/data/knowledge
#
WORKSPACE_DIR=./workspace

# CHUNK_STORE_DIR：SVO 知識切片快取
#   - 系統自動生成，儲存 sentence chunk 原文供自我精煉迴圈讀取
#   - 通常與 WORKSPACE_DIR 放在同一磁碟即可
#   - 可視需要遷移至其他路徑（例如 SSD 以加速讀取）
#
CHUNK_STORE_DIR=./chunk_store

# CONFIDENCE_CALIBRATION：LLM 信心校準係數（☆9）
#   - 預設 0.9，讓模型稍微保守，避免過度自信停止精煉
#   - 設為 1.0 則完全信任 LLM 自報
#
CONFIDENCE_CALIBRATION=0.9

# STAGING_CRON_INTERVAL：暫存區自動分類排程（☆7）
#   - 0 = 停用（預設）
#   - 正整數 = 每 N 分鐘自動掃描 _staging/ 並分配分數達門檻的文件
#
STAGING_CRON_INTERVAL=0

# ── 世界知識聯邦（選用）──────────────────────────────────────
# 你的 instance 識別碼（出現在 registry.json 中，請取唯一名稱）
INSTANCE_ID=local
# 本機 registry 路徑
REGISTRY_PATH=./registry.json
# GitHub 上共享 registry 的 Raw URL（留空則只使用本機 registry）
GITHUB_REGISTRY_URL=
